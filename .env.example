# ─── AI ───────────────────────────────────────────
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ─── Database (Supabase) ─────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Only needed for scripts/setup_db.py:
SUPABASE_DB_PASSWORD=your_db_password

# ─── Google Calendar ─────────────────────────────
GOOGLE_CALENDAR_ID=your@gmail.com
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/gcal.json

# ─── Twilio (Phone) ─────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+19145550123

# ─── Server ──────────────────────────────────────
PORT=8000
FRONTEND_URL=http://localhost:5173
APP_DOMAIN=localhost:8000

# ─── Production Settings ─────────────────────────
# Set to "production" for deployed environments
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=
# Gym timezone (used for calendar queries)
GYM_TIMEZONE=America/New_York
